# Private key material — must never be committed
pki/**/*.key
pki/**/*.pem
*.key
*.p12
*.pfx

# Regenerable PKI artifacts (script recreates on demand)
pki/**/*.crt
pki/**/*.csr
pki/**/*.srl
pki/**/*.crl

# CA database state (managed by `openssl ca`, Phase 5)
pki/ca/index.txt
pki/ca/index.txt.attr
pki/ca/index.txt.old
pki/ca/index.txt.attr.old
pki/ca/serial
pki/ca/serial.old
pki/ca/crlnumber
pki/ca/crlnumber.old
pki/ca/newcerts/
__pycache__/
*.pyc
.venv/
venv/
.env
*.log
logs/
.DS_Store

# Phase-5 server lifecycle (managed by the Makefile)
.server.pid
.server.log

# Phase-5 cert-pinning fingerprint (regenerable via `make pin`)
pki/server/server.fingerprint
pki/nginx/nginx.fingerprint

# Test-suite artifacts (pytest + coverage.py)
.pytest_cache/
.coverage
.coverage.*
htmlcov/

# nginx v1.2 runtime — generated from nginx/nginx.conf by nginx-test-gen.sh
nginx/nginx-test.conf
nginx/logs/
.nginx.log

# Apache v1.3 runtime — generated from apache/apache.conf by apache-test-gen.sh
apache/apache-test.conf
apache/logs/
.apache.log

# Apache cert pinning fingerprint (regenerable via `make pin-apache`)
pki/apache/apache.fingerprint
